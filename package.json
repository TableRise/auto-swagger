{
  "name": "@tablerise/auto-swagger",
  "version": "5.4.1",
  "description": "A library to auto generate swagger documents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "dist": "npm run build && copy /Y package.json dist && cd dist && npm publish",
    "test": "npm run build && node --test tests/auto-swagger.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/TableRise/auto-swagger.git"
  },
  "author": "@table-rise/adson-gomes-oliveira",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/TableRise/auto-swagger.git./issues"
  },
  "homepage": "https://github.com/TableRise/auto-swagger.git.#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/express": "4.17.19",
    "@types/node": "20.1.1",
    "supertest": "7.2.2",
    "typescript": "5.4.5"
  },
  "files": [
    "/dist"
  ],
  "dependencies": {
    "@faker-js/faker": "10.4.0",
    "dotenv": "16.3.1",
    "express": "^4.18.0 || ^5.0.0",
    "randexp": "0.5.3",
    "swagger-ui-dist": "5.32.6",
    "zod": "4.2.1",
    "zod-schema-faker": "2.1.1"
  }
}
